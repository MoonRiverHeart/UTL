{
  "name": "@utl/server",
  "version": "0.1.0",
  "description": "UTL服务端 - Express + Prisma + MCP协议 + WebSocket",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "npx tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@utl/language": "workspace:*",
    "express": "^4.18.0",
    "socket.io": "^4.7.0",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.0",
    "cors": "^2.8.0",
    "dotenv": "^16.3.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/bcryptjs": "^2.4.0",
    "@types/cors": "^2.8.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.3.0",
    "prisma": "5.22.0",
    "tsx": "^4.7.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0"
  },
  "files": [
    "dist"
  ],
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}